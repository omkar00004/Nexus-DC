# --- API keys ---
GEMINI_API_KEY=your-ai-studio-key
# comma-separated pool; calls round-robin and rate-limited keys are skipped
GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

# --- optional: NVIDIA NIM fallback (build.nvidia.com, OpenAI-compatible) ---
# Used automatically when ALL Groq keys are rate-limited. Empty = disabled.
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama-3.1-405b-instruct

# --- Model registry (validated against live models.list at API startup) ---
MODEL_REASONING_PRO=gemini-3.5-flash          # gemini-3.1-pro-preview with billing
MODEL_REASONING_FLASH=gemini-3.5-flash
MODEL_VISION=gemini-flash-latest
MODEL_EXTRACTION=openai/gpt-oss-120b
MODEL_EXTRACTION_FALLBACK=openai/gpt-oss-20b

# --- optional: Langfuse LLM observability (traces, latency, token usage) ---
# No-op when empty. Get keys at cloud.langfuse.com (free tier).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Demo heuristics (acknowledged assumptions) ---
CONVERGENCE_THRESHOLD=0.65
SLA_PENALTY_PER_DAY_USD=50000
